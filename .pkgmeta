package-as: BawrSpam

enable-nolib-creation: no
enable-toc-creation: yes

manual-changelog:
  filename: RELEASE_NOTES.html
  markup-type: html

# No `externals:` block — BawrSpam vendors its libraries directly in Libs/
# (see .gitignore: "Libs/ is tracked … manual vendor pattern"). The packager
# ships them as-is from the checkout rather than fetching them at build time.

ignore:
  - .git
  - .gitignore
  - .github
  - .pkgmeta
  - .release
  - .worktrees
  - .claude
  - .codex
  - AGENTS.md
  # Drop only the agent doc; README.md (+ packager-generated CHANGELOG) ship.
  # NOTE: no inline comments on ignore entries — the packager reads them literally.
  - BawrSpam_Dev
  - CLAUDE.md
  - RELEASE_NOTES.md
  - RELEASE_NOTES.html
